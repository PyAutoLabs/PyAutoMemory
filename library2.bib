number = {2},
pages = {126--138},
title = {{Lens models of herschel-selected galaxies from high-resolution near-IR observations}},
url = {http://stacks.iop.org/0004-637X/797/i=2/a=138?key=crossref.4244e3e383c14bc754f84ba66e968d77{\%}5Cnpapers3://publication/doi/10.1088/0004-637X/797/2/138},
volume = {797},
