eprint = {0601040},
file = {:home/jammy/.local/share/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Yang et al. - 2006 - The alignment between the distribution of satellites and the orientation of their central galaxy.pdf:pdf},
issn = {00358711},
journal = {Monthly Notices of the Royal Astronomical Society},
keywords = {Dark matter,Galaxies: haloes,Galaxies: structure,Large-scale structure of Universe,Methods: statistical},
number = {3},
