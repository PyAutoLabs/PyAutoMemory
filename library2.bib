issn = {0004-637X},
journal = {$\backslash$Apj},
keywords = {Cosmology: Dark Matter,Galaxies: Fundamental Parameters,Galaxies: Kinematics and Dynamics},
month = {apr},
pages = {920--943},
title = {{Mass Models for Low Surface Brightness Galaxies with High Resolution Optical Velocity Fields}},
url = {http://arxiv.org/abs/0712.0860{\%}0Ahttp://dx.doi.org/10.1086/527543},
volume = {676},
year = {2007}
}
