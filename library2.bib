issn = {00358711},
journal = {Monthly Notices of the Royal Astronomical Society},
keywords = {Galaxies: bulges,Galaxies:elliptical and lenticular, cD,Galaxies:kinematics and dynamics,Galaxies:structure},
number = {3},
