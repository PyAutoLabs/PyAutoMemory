issn = {13652966},
journal = {Monthly Notices of the Royal Astronomical Society},
keywords = {Cosmological parameters,Distance scale,Galaxies: structure,Gravitational lensing: strong,HE 0435-1223,HE 1104-1805,Quasars: individual:B1608+656,RXJ1131-1231,WFI2033-4723},
number = {3},
