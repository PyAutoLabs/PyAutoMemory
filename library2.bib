journal = {The Astronomical Journal},
keywords = {COSMOLOGY: DISTANCE SCALE,COSMOLOGY: GRAVITATIONAL LENSING,GALAXIES: DISTANCES AND REDSHIFTS,GALAXIES: QUASARS: INDIVIDUAL: ALPHANUMERIC: B204},
month = {feb},
number = {2},
pages = {658--670},
pmid = {740917},
primaryClass = {astro-ph},
title = {{B2045+265: A New Four-Image Gravitational Lens from CLASS}},
url = {http://arxiv.org/abs/astro-ph/9811167{\%}0Ahttp://dx.doi.org/10.1086/300724},
