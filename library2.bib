keywords = {Cosmology: observations,Gravitational lensing},
month = {may},
number = {1},
pages = {1--12},
primaryClass = {astro-ph},
title = {{The Cosmic Lens All-Sky Survey -I. Source selection and observations}},
volume = {341},
year = {2003}
}
