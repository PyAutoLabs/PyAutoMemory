arxivId = {1406.1487},
author = {Calanog, J. A. and Fu, Hai and Cooray, A. and Wardlow, J. and Ma, B. and Amber, S. and Baker, A. J. and Baes, M. and Bock, J. and Bourne, N. and Bussmann, R. S. and Casey, C. M. and Chapman, S. C. and Clements, D. L. and Conley, A. and Dannerbauer, H. and {De Zotti}, G. and Dunne, L. and Dye, S. and Eales, S. and Farrah, D. and Furlanetto, C. and Harris, A. I. and Ivison, R. J. and Kim, S. and Maddox, S. J. and Magdis, G. and Messias, H. and Micha{\l}lowski, M. J. and Negrello, M. and Nightingale, J. and O'Bryan, J. M. and Oliver, S. J. and Riechers, D. and Scott, D. and Serjeant, S. and Simpson, J. and Smith, M. and Timmons, N. and Thacker, C. and Valiante, E. and Vieira, J. D.},
