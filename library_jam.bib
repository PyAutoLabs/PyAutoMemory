keywords = {Instrumentation: detectors,Methods: data analysis,Space vehicles: instruments,Techniques: image processing},
month = {nov},
number = {1},
pages = {L109--L113},
title = {{Charge transfer inefficiency in the Hubble Space Telescope since Servicing Mission 4}},
volume = {409},
