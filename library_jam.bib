year = {2018}
}
@article{Guo2011,
abstract = {We report the detection of color gradients in massive (stellar mass $\backslash$nM{\{}$\backslash$textgreater{\}}10{\{}$\backslash$textless{\}}SUP{\{}$\backslash$textgreater{\}}10{\{}$\backslash$textless{\}}/SUP{\{}$\backslash$textgreater{\}} Msun) galaxies with low specific star formation $\backslash$nrate (SSFR{\{}$\backslash$textless{\}}10{\{}$\backslash$textless{\}}SUP{\{}$\backslash$textgreater{\}}-11{\{}$\backslash$textless{\}}/SUP{\{}$\backslash$textgreater{\}}/yr) at redshift z 2. The galaxies are $\backslash$nselected by means of SED fitting to spectral population synthesis models $\backslash$nusing the Great Observatories Origins Deep Survey (GOODS) broad--band $\backslash$nphotometry, which spans the optical, near--IR and mid--IR windows, $\backslash$naugmented by recent ultra--deep near--IR images obtained with HST WFC3. $\backslash$nThe estimated stellar mass and SSFR would place these galaxies among $\backslash$ntoday's Hubble early types, while their rest--frame optical morphology, $\backslash$nas shown by the WFC3 images, is consistent with that of spheroidal $\backslash$nsystems. The inner regions of these galaxies are found to have redder $\backslash$nrest UV--optical colors than their outer parts. The slope of the color $\backslash$ngradient has no obvious dependence on the redshift and stellar mass of $\backslash$nthe galaxies. It does depend, however, on the overall dust obscuration $\backslash$nand rest-frame U-V color of the galaxies mildly, with more obscured or $\backslash$nredder galaxies having steeper color gradient. The slope of the color $\backslash$ngradient is generally steeper than that of local early-type galaxies. We $\backslash$nfind that the gradient of a single parameter (age, extinction or $\backslash$nmetallicity) cannot fully explain the observed color gradient. To study $\backslash$nthe physical implications of these color gradients, we fit spatially $\backslash$nresolved HST seven--bands photometry from ACS and WFC3 images (BVizYJH) $\backslash$nin concentric shells across the light profile of each galaxies, sampling $\backslash$nthe color gradients. Regardless of the assumed metallicity gradient, the $\backslash$nredder inner regions always have slightly higher dust obscuration than $\backslash$nthe bluer outer regions, implying that a dust gradient may partly $\backslash$ncontribute to the observed color gradients. Because of the $\backslash$nage--metallicity degeneracy, the derived age gradient is coupled with $\backslash$nthe assumed metallicity gradient. We discuss the plausibility and $\backslash$nimplication of each derived age gradient.},
author = {Guo, Yicheng and Giavalisco, M and Cassata, P and Koekemoer, A},
journal = {Bulletin of the {\{}American{\}} {\{}Astronomical{\}} {\{}Society{\}}},
pages = {18},
title = {{Color {\{}Gradients{\}} and {\{}Stellar{\}} {\{}Population{\}} {\{}Gradients{\}} of {\{}Early{\}}-type {\{}Galaxies{\}} at z 2 in the {\{}Hubble{\}} {\{}Ultra{\}} {\{}Deep{\}} {\{}Field{\}}}},
url = {http://cdsads.u-strasbg.fr/abs/2011AAS...21733503G},
volume = {217},
year = {2011}
}
@article{Momcheva2015,
abstract = {We present the spectroscopic redshift catalog from a wide-field survey of the fields of 28 galaxy-mass strong gravitational lenses. We discuss the acquisition and reduction of the survey data, collected over 40 nights of 6.5 m MMT and Magellan time, employing four different multiobject spectrographs. We determine that no biases are introduced by combining data sets obtained with different telescope and spectrograph combinations. Special care is taken to determine redshift uncertainties using repeat observations. The redshift catalog consists of 9,768 new and unique galaxy redshifts. 82.4{\%} of the catalog redshifts are between z = 0.1 and z = 0.7, and the catalog median redshift. The data from this survey will be used to study the lens environments and line-of-sight structures to gain a better understanding of the effects of large-scale structure on lens statistics and lens-derived parameters.},
