issn = {0035-8711},
journal = {Monthly Notices of the Royal Astronomical Society},
keywords = {data analysis,gravitational lensing,methods,strong},
month = {jan},
number = {2},
pages = {1819--1829},
title = {{Trans-dimensional Bayesian inference for gravitational lens substructures}},
url = {http://arxiv.org/abs/1508.00662},
volume = {455},
year = {2016}
}
