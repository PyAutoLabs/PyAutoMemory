file = {:home/jammy/.local/share/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Seabroke et al. - 2010 - Modelling Gaia CCD pixels with Silvaco 3D engineering software.pdf:pdf},
isbn = {9782759806089},
