file = {:home/jammy/.local/share/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Shajib et al. - 2018 - Is every strong lens model unhappy in its own way Uniform modelling of a sample of 12 quadruply imaged quasars.pdf:pdf},
issn = {13652966},
