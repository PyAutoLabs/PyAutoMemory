isbn = {9783319474427},
issn = {16113349},
journal = {Lecture Notes in Computer Science (including subseries Lecture Notes in Artificial Intelligence and Lecture Notes in Bioinformatics)},
keywords = {C,Code coverage,Embedded systems,UEFI,Unit test},
number = {1},
pages = {218--224},
pmid = {22210669},
title = {{UTTOS: A tool for testing UEFI code in OS environment}},
url = {http://stacks.iop.org/0004-637X/798/i=1/a=7?key=crossref.ce8f697114eeb3752ff6da50e3e66986},
volume = {9976 LNCS},
year = {2016}
}
